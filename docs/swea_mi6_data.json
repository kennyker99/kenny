  "tools": [
    {
      "id": "risk-calculator",
      "name": "风险计算器",
      "category": "risk-management",
      "description": "计算单笔交易的风险金额和仓位大小",
      "inputs": [
        {
          "name": "accountSize",
          "label": "账户金额",
          "type": "number",
          "unit": "USD",
          "placeholder": "10000"
        },
        {
          "name": "riskPercent",
          "label": "风险百分比",
          "type": "number",
          "unit": "%",
          "placeholder": "2",
          "max": 5
        },
        {
          "name": "stopLossPoints",
          "label": "止损点数",
          "type": "number",
          "unit": "pips",
          "placeholder": "50"
        }
      ],
      "outputs": [
        {
          "name": "riskAmount",
          "label": "风险金额",
          "formula": "accountSize * riskPercent / 100"
        },
        {
          "name": "positionSize",
          "label": "仓位大小",
          "formula": "riskAmount / stopLossPoints"
        }
      ],
      "relatedModules": ["mi5"]
    },
    {
      "id": "risk-reward-calculator",
      "name": "盈亏比计算器",
      "category": "risk-management",
      "description": "计算盈亏比和期望收益",
      "inputs": [
        {
          "name": "stopLossPoints",
          "label": "止损点数",
          "type": "number",
          "unit": "pips"
        },
        {
          "name": "takeProfitPoints",
          "label": "止盈点数",
          "type": "number",
          "unit": "pips"
        },
        {
          "name": "winRate",
          "label": "胜率",
          "type": "number",
          "unit": "%",
          "min": 0,
          "max": 100
        }
      ],
      "outputs": [
        {
          "name": "riskRewardRatio",
          "label": "盈亏比",
          "formula": "takeProfitPoints / stopLossPoints"
        },
        {
          "name": "expectedReturn",
          "label": "期望收益",
          "formula": "(winRate/100) * takeProfitPoints - ((100-winRate)/100) * stopLossPoints"
        }
      ],
      "relatedModules": ["mi5"]
    },
