      "totalLessons": 1,
      "estimatedHours": 2,
      "coreQuestion": "如何控制风险？",
      "lessons": [
        {
          "id": "mi5-1",
          "order": 1,
          "title": "盈利 & 止损的艺术 | Art of TP & SL",
          "titleEn": "Take Profit & Stop Loss Management",
          "description": "教授如何科学地设置止盈（Take Profit）和止损（Stop Loss），确保每一笔交易都具有合理的盈亏比",
          "duration": 1100,
          "difficulty": 2,
          "type": "video",
          "keyPoints": [
            "止损的重要性",
            "止盈的设置方法",
            "盈亏比的计算",
            "风险管理的最佳实践"
          ],
          "riskManagement": {
            "stopLoss": {
              "name": "止损 (SL)",
              "definition": "损失的最大承受额",
              "importance": "⭐⭐⭐⭐⭐ 必须设置",
              "principles": [
                "基于技术位置设置（不是随意设置）",
                "通常设在关键支撑/阻力位下方",
                "不随意移动，保持纪律性"
              ],
              "example": "在1.2000买入，止损设在1.1950（50点风险）"
            },
            "takeProfit": {
              "name": "止盈 (TP)",
              "definition": "目标利润位置",
              "importance": "⭐⭐⭐⭐⭐ 提前规划",
              "principles": [
                "基于技术目标设置",
                "可以分批止盈",
                "根据盈亏比确定"
              ],
              "example": "止盈设在1.2100（100点利润），盈亏比 1:2"
            },
            "riskRewardRatio": {
              "name": "盈亏比 (R:R)",
              "definition": "止盈与止损的比例",
              "importance": "⭐⭐⭐⭐⭐ 最少1:2",
              "formula": "TP距离 / SL距离",
              "example": "SL 50点，TP 100点，盈亏比 1:2",
              "minimumRequirement": "1:2 或更高"
            },
            "positionSizing": {
              "name": "仓位管理",
              "definition": "单笔风险占账户的比例",
              "importance": "⭐⭐⭐⭐⭐ 通常≤2%",
              "formula": "风险金额 = 账户余额 × 风险百分比",
              "example": "账户10000美元，风险2%，则风险金额200美元"
            }
          },
          "keyFormulas": [
            {
              "name": "期望收益",
              "formula": "期望收益 = 胜率 × 平均盈利 - (1-胜率) × 平均亏损",
              "example": "胜率60%，盈亏比1:2，期望收益 = 60% × 2 - 40% × 1 = 0.8（正期望）"
            },
            {
              "name": "风险金额",
              "formula": "风险金额 = 账户余额 × 风险百分比",
              "example": "账户10000，风险2%，风险金额 = 200"
            },
            {
              "name": "仓位大小",
              "formula": "仓位大小 = 风险金额 / 止损点数",
              "example": "风险200，止损50点，仓位 = 200/50 = 4手"
            }
          ],
          "bestPractices": [
            "每笔交易风险不超过账户的 2%",
            "盈亏比至少 1:2 或更高",
